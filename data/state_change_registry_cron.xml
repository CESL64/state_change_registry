<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_state_change_registry_send_pending_notifications" model="ir.cron">
            <field name="name">State Change Registry: Enviar notificaciones pendientes</field>
            <field name="model_id" ref="state_change_registry.model_state_change_registry"/>
            <field name="state">code</field>
            <field name="code">model.cron_send_pending_state_change_notifications()</field>
            <field name="active" eval="True"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall" eval="(datetime.now() + timedelta(days=(1 if datetime.now().hour &gt;= 23 else 0))).strftime('%Y-%m-%d 23:00:00')"/>
        </record>
    </data>
</odoo>
